#!/usr/bin/python3
import os

"""
Interactive Command Tutor Script:

This program helps students learn and practice Linux shell commands
from Basic Command I and Basic Command II.

Main features:

1. Learn Mode:
   Shows Linux commands with their meaning and example usage.
   This helps students review commands before taking the quiz.

2. Quiz Mode:
   Asks the user direct questions about Linux commands and checks the answer.
   The user receives a score at the end.

3. Practice Mode:
   Gives the user a real command-line task and asks them to type the correct command.
   This mode is more practical because the user must write the command, not just choose an answer.

4. Score System:
   Counts correct answers in Quiz Mode and Practice Mode.
   At the end, it displays the final score.

5. Exit:
   Allows the user to safely close the program from the main menu.
"""

# =========================
# DATA SECTION
# =========================
# Here we store the main data used by the program:
# - Linux commands for Learn Mode
# - Questions for Quiz Mode
# - Tasks for Practice Mode
#
# This section should be done early because the other features depend on it.

#[command, meaning, example]
commands = [
    ["pwd", "Shows the current working directory", "pwd"],
    ["ls", "Lists files and directories", "ls -la"],
    ["cd", "Changes the current directory", "cd Desktop"],
    ["cat", "Displays the content of a file", "cat file.txt"],
    ["mkdir", "Creates a new directory", "mkdir project"]
]

quiz_questions = [
    ["Which command shows the current directory?", "pwd"],
    ["Which command lists files and directories?", "ls"],
    ["Which command changes the current directory?", "cd"],
    ["Which command displays the content of a file?", "cat"],
    ["Which command creates a new directory?", "mkdir"]
]

practice_tasks = [
    ["Create a folder called test", "mkdir test"],
    ["Create an empty file called notes.txt", "touch notes.txt"],
    ["Show the content of file.txt", "cat file.txt"],
    ["List files with detailed information", "ls -l"],
    ["Show the current directory", "pwd"]
]

# =========================
# HELPER FUNCTIONS
# =========================
# Helper functions are small functions used by different parts of the program.

def pause():
    input("\nPress 'Enter' to return to the main menu...")
    

def clear_screen():
    os.system("clear")
    
def print_header(title):
    print("==============================")
    print("--- ", title)
    print("==============================\n")
    
# =========================
# LEARN MODE
# =========================
# This function displays Linux commands with their meanings and examples.
#
# Depends on:
# - DATA SECTION
#
# Does not depend on:
# - Quiz Mode
# - Practice Mode

def learn_mode():
    clear_screen()
    print_header("Learn Mode")
    for command in commands:
        print("\nCommand:", command[0])
        print("Meaning:", command[1])
        print("Example:", command[2])

    pause()

# =========================
# QUIZ MODE
# =========================
# This function asks the user questions about Linux commands.
# It checks the user's answer and counts the score.
#
# Depends on:
# - DATA SECTION
# - SCORE SYSTEM
#
# Does not depend on:
# - Learn Mode
# - Practice Mode

def quiz_mode():
    clear_screen()
    print_header("Quiz Mode")

    score = 0

    for question in quiz_questions:
        answer = input(question[0] + " ")

        # lower() makes the answer lowercase, so PWD and pwd are treated the same
        answer = answer.lower()

        if answer == question[1]:
            print("Correct!")
            score = score + 1
        else:
            print("Wrong. Correct answer is:", question[1])

    show_score(score, len(quiz_questions))
    pause()
# =========================
# PRACTICE MODE
# =========================
# This function gives the user a real command-line task.
# The user must type the correct Linux command.
#
# Example:
# Task: Create a folder called test
# Correct answer: mkdir test
#
# Depends on:
# - DATA SECTION
# - SCORE SYSTEM
#
# Does not depend on:
# - Learn Mode
# - Quiz Mode


def practice_mode():
    clear_screen()
    print_header("Practice Mode")

    score = 0

    for task in practice_tasks:
        print("\nTask:", task[0])
        answer = input("Type the command: ")

        # lower() makes the answer lowercase
        # strip() removes extra spaces at the beginning and end
        answer = answer.lower().strip()

        if answer == task[1]:
            print("Correct!")
            score = score + 1
        else:
            print("Wrong. Correct answer is:", task[1])

    show_score(score, len(practice_tasks))
    pause()
    
# =========================
# SCORE SYSTEM
# =========================
# This part handles score counting and final score display.
#
# Used by:
# - Quiz Mode
# - Practice Mode
#
# This can be simple at first: count correct answers and print final score.
# Later, it can be improved with percentage or feedback messages.

def show_score(score, total):
    print("\nFinal score:", score, "/", total)

    if score == total:
        print("Excellent! You got all answers correct.")
    elif score >= total / 2:
        print("Good job, but you can still improve.")
    else:
        print("You need more practice. Try Learn Mode again.")
        
# =========================
# MAIN MENU
# =========================
# This is the main control area of the program.
# It shows the user the available options:
# 1. Learn Mode
# 2. Quiz Mode
# 3. Practice Mode
# 4. Exit
#
# Depends on:
# - Learn Mode
# - Quiz Mode
# - Practice Mode
#
# Important:
# The main menu should be completed after the main feature functions exist,
# because it will call those functions based on the user's choice.

while True:
    clear_screen()
    print_header("Interactive Command Tutor")
    print("1. Learn Mode")
    print("2. Quiz Mode")
    print("3. Practice Mode")
    print("4. Exit")

    choice = input("Choose an option: ")

    if choice == "1":
      learn_mode()
    elif choice == "2":
      quiz_mode()
    elif choice == "3":
      practice_mode()
    elif choice == "4":
      print("Goodbye")
      break
    else:
      print("invalid choice, try again.")
      pause()

# =========================
# PROGRAM START
# =========================
# This is where the program begins running.
# It should start by showing the main menu.

